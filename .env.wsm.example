# WSM Saleor MCP Configuration
# Allow connections to any WSM dev tenant
ALLOWED_DOMAIN_PATTERN=https:\/\/api[\.-].*\.(wsm-dev\.com|prestigemustang\.com)\/graphql\/

# To test with a specific tenant:
# 1. Get a staff auth token from the tenant's Saleor dashboard
# 2. Use these headers when connecting:
#    X-Saleor-API-URL: https://api.prestigemustang.com/graphql/
#    X-Saleor-Auth-Token: <your-staff-token>
#
# The token needs MANAGE_PRODUCTS and MANAGE_ORDERS permissions.
# Create one in Saleor Dashboard > Configuration > Service Accounts
